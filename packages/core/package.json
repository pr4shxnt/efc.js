{
  "name": "express-file-cluster",
  "version": "0.2.11",
  "description": "Enterprise-grade, zero-boilerplate backend framework with file-based routing and multi-core clustering",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "efc": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js",
      "require": "./dist/auth/index.cjs"
    },
    "./tasks": {
      "types": "./dist/tasks/index.d.ts",
      "import": "./dist/tasks/index.js",
      "require": "./dist/tasks/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "commander": "^12.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.6",
    "express": "^4.19.0",
    "jose": "^6.2.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "bullmq": "^5.79.1",
    "mongoose": "^9.7.2",
    "supertest": "^7.2.2",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "bullmq": ">=5.0.0",
    "mongoose": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "bullmq": {
      "optional": true
    },
    "mongoose": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
